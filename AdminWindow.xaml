<Window x:Class="DoAnCN_Net.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoAnCN_Net"
        mc:Ignorable="d"
        Title="Adora - Hệ thống quản lý tiệc cưới"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg"       Color="#1a1a2e"/>
        <SolidColorBrush x:Key="SidebarHover"    Color="#16213e"/>
        <SolidColorBrush x:Key="SidebarSelected" Color="#0f3460"/>
        <SolidColorBrush x:Key="AccentColor"     Color="#e94560"/>
        <SolidColorBrush x:Key="HeaderBg"        Color="#ffffff"/>

        <Style x:Key="MenuListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Height"     Value="50"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Indicator"
                                        Grid.Column="0"
                                        Width="4" Height="30"
                                        Background="{StaticResource AccentColor}"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed"/>

                                <TextBlock x:Name="Icon"
                                           Grid.Column="1"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>

                                <ContentPresenter x:Name="Content"
                                                  Grid.Column="2"
                                                  Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"
                                                  Margin="5,0,0,0"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"  Property="Background" Value="{StaticResource SidebarHover}"/>
                                <Setter TargetName="Icon"    Property="Foreground" Value="White"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border"     Property="Background"  Value="{StaticResource SidebarSelected}"/>
                                <Setter TargetName="Icon"       Property="Foreground"  Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Indicator"  Property="Visibility"  Value="Visible"/>
                                <Setter Property="Foreground"   Value="White"/>
                                <Setter Property="FontWeight"   Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="15,10"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SidebarBg}" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource SidebarBg}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0">
                        <TextBlock Text="🎉 Adora"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" | Hệ thống quản lý tiệc cưới"
                                   FontSize="12" Foreground="#888888"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <Button x:Name="btnMinimize" Content="─"
                                Width="30" Height="30"
                                Click="MinimizeWindow_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#CCCCCC" Cursor="Hand" FontSize="16"/>
                        <Button x:Name="btnMaximize" Content="□"
                                Width="30" Height="30"
                                Click="MaximizeWindow_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#CCCCCC" Cursor="Hand" FontSize="14"
                                Margin="5,0,5,0"/>
                        <Button x:Name="btnClose" Content="✕"
                                Width="30" Height="30"
                                Click="CloseWindow_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#CCCCCC" Cursor="Hand">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                            To="#E81123" Duration="0:0:0.1"/>
                                            <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                            To="White" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Button.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                            To="Transparent" Duration="0:0:0.1"/>
                                            <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                            To="#CCCCCC" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" x:Name="MenuColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User Info -->
                        <Border Grid.Row="0" Background="{StaticResource SidebarHover}"
                                Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <Border Width="60" Height="60" CornerRadius="30"
                                        Background="{StaticResource AccentColor}"
                                        HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock Text="AD" FontSize="24" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Xin chào, Admin"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="Quản trị viên"
                                           FontSize="12" Foreground="#888888"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Menu List -->
                        <ListView Grid.Row="1"
                                  x:Name="lvMenu"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource MenuListViewItemStyle}"
                                  SelectionChanged="lvMenu_SelectionChanged"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <!-- Tổng quan — biểu đồ/dashboard -->
                            <ListViewItem Content="Tổng quan"  Tag="&#xE9D2;"/>

                            <Separator/>

                            <!-- Chi nhánh — tòa nhà -->
                            <ListViewItem Content="Chi nhánh"  Tag="&#xE825;"/>
                            <!-- Sảnh — phòng/địa điểm -->
                            <ListViewItem Content="Sảnh"       Tag="&#xE83F;"/>
                            <!-- Khách hàng — người dùng -->
                            <ListViewItem Content="Khách hàng" Tag="&#xE716;"/>
                            <!-- Đặt sảnh — lịch đặt -->
                            <ListViewItem Content="Đặt sảnh"   Tag="&#xE787;"/>

                            <Separator/>

                            <!-- Menu — thực đơn -->
                            <ListViewItem Content="Menu"       Tag="&#xE7BF;"/>
                            <!-- Món ăn — đồ ăn -->
                            <ListViewItem Content="Món ăn"     Tag="&#xE7D9;"/>
                            <!-- Dịch vụ — ngôi sao dịch vụ -->
                            <ListViewItem Content="Dịch vụ"    Tag="&#xE734;"/>

                            <Separator/>

                            <!-- Khuyến mãi — quà tặng -->
                            <ListViewItem Content="Khuyến mãi" Tag="&#xE8EF;"/>
                            <!-- Hóa đơn — chứng từ -->
                            <ListViewItem Content="Hóa đơn"    Tag="&#xE9F5;"/>
                            <!-- Đổi lịch — đồng bộ/làm mới -->
                            <ListViewItem Content="Đổi lịch"   Tag="&#xE895;"/>

                        </ListView>

                        <!-- Đăng xuất -->
                        <Border Grid.Row="2" Background="{StaticResource SidebarHover}" Margin="0,20,0,0">
                            <Border x:Name="logoutItem"
                                    Height="50"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Logout_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource SidebarHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xF3B1;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" Foreground="#CCCCCC"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="Đăng xuất"
                                               Foreground="#CCCCCC" FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"/>
                                </Grid>
                            </Border>
                        </Border>

                    </Grid>
                </Border>

                <!-- CONTENT -->
                <Grid Grid.Column="1" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderBg}"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Button x:Name="btnToggleMenu"
                                    Content="☰" Width="40" Height="40"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="15,0,0,0"
                                    Click="ToggleMenu"
                                    Background="Transparent" BorderThickness="0"
                                    FontSize="20" Foreground="#333333" Cursor="Hand"/>

                            <TextBlock x:Name="txtBreadcrumb"
                                       Text="Dashboard"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#555555"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,20,0">
                                <Button Content="🔔" Width="35" Height="35"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="18" Cursor="Hand" ToolTip="Thông báo"/>
                                <Button Content="⚙️" Width="35" Height="35"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="18" Cursor="Hand"
                                        Margin="5,0,0,0" ToolTip="Cài đặt"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- FRAME -->
                    <Frame x:Name="MainFrame"
                           Grid.Row="1"
                           Margin="0,0,0,10"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>