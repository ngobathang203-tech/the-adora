<UserControl x:Class="DoAnCN_Net.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    Background="#F4F6FA">

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Dashboard"
                           FontSize="30"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- CARDS -->
                <UniformGrid Columns="4" Margin="0,0,0,20">

                    <Border Background="#4CAF50" CornerRadius="10" Margin="8">
                        <StackPanel Margin="15">
                            <TextBlock Text="Tổng đơn" Foreground="White"/>
                            <TextBlock x:Name="txtTongDon"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2196F3" CornerRadius="10" Margin="8">
                        <StackPanel Margin="15">
                            <TextBlock Text="Doanh thu" Foreground="White"/>
                            <TextBlock x:Name="txtDoanhThu"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF9800" CornerRadius="10" Margin="8">
                        <StackPanel Margin="15">
                            <TextBlock Text="Tiệc hôm nay" Foreground="White"/>
                            <TextBlock x:Name="txtTiecHomNay"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F44336" CornerRadius="10" Margin="8">
                        <StackPanel Margin="15">
                            <TextBlock Text="Chờ duyệt" Foreground="White"/>
                            <TextBlock x:Name="txtChoDuyet"
                                       Text="0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- TABLE -->
                <!-- TABLE -->
                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Danh sách tiệc gần nhất"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

                        <DataGrid x:Name="dgData"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="250"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên sự kiện"
                                    Binding="{Binding TenSuKien}"
                                    Width="*"/>
                                <DataGridTextColumn Header="Khách hàng"
                                    Binding="{Binding TenKhachHang}"
                                    Width="*"/>
                                <DataGridTextColumn Header="Ngày"
                                    Binding="{Binding NgayToChuc}"
                                    Width="*"/>
                                <DataGridTextColumn Header="Trạng thái"
                                    Binding="{Binding TrangThai}"
                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>
                </Border>

                <!-- CHART -->
                <Grid Height="380">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- COLUMN CHART -->
                    <Border Background="White" CornerRadius="12" Margin="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Doanh thu theo tháng"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <lvc:CartesianChart Series="{Binding ColumnSeries}" Height="300">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding Labels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Giá trị"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </StackPanel>
                    </Border>

                    <!-- PIE CHART -->
                    <Border Background="White" CornerRadius="12" Margin="8" Padding="15" Grid.Column="1">
                        <StackPanel>
                            <TextBlock Text="Trạng thái đơn"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <lvc:PieChart Series="{Binding PieSeries}"
                                          Height="300"
                                          LegendLocation="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>