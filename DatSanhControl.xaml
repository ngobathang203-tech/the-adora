<UserControl x:Class="DoAnCN_Net.DatSanhControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDFAF5">

    <UserControl.Resources>

        <!-- ===== PALETTE (đồng bộ toàn app) ===== -->
        <SolidColorBrush x:Key="GoldPrimary"  Color="#C9A84C"/>
        <SolidColorBrush x:Key="GoldLight"    Color="#D4A940"/>
        <SolidColorBrush x:Key="GoldTint"     Color="#FBF0CC"/>
        <SolidColorBrush x:Key="SurfaceWarm"  Color="#F5EDD8"/>
        <SolidColorBrush x:Key="CardBorder"   Color="#E8D9B5"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#2A1F0A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B5430"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#A08050"/>

        <LinearGradientBrush x:Key="GoldBtn" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C9A84C" Offset="0"/>
            <GradientStop Color="#D4A940" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== BASE BUTTON ===== -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Nút đổi trạng thái (cam nhạt) -->
        <Style x:Key="BtnStatus" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#FBF0CC"/>
            <Setter Property="Foreground" Value="#C9A84C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource GoldBtn}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút xóa (đỏ nhạt) -->
        <Style x:Key="BtnDelete" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#FFF0F0"/>
            <Setter Property="Foreground" Value="#B85450"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B85450"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="CboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="TxtStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2A1F0A"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B5430"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- DataGrid style -->
        <Style x:Key="DgStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FDFAF5"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <!-- Header cột -->
        <Style x:Key="GoldHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5EDD8"/>
            <Setter Property="Foreground" Value="#6B5430"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Row style -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="#F0E8D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FBF0CC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDFAF5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell style -->
        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#2A1F0A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <DockPanel Margin="20" LastChildFill="True">

        <!-- ═══ HEADER + STATS ═══ -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Quản lý Đặt Sảnh"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#2A1F0A"
                           FontFamily="Playfair Display, Georgia, serif"/>
                <TextBlock x:Name="lblTongDon" Text="Đang tải..."
                           FontSize="11" Foreground="#A08050"
                           FontFamily="Montserrat, Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Stat: Đang đặt -->
            <Border Grid.Column="1" Background="#F5EDD8"
                    BorderBrush="#E8D9B5" BorderThickness="1"
                    Padding="16,8" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="lblDangDat" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#C9A84C" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                    <TextBlock Text="Đang đặt" FontSize="10"
                               Foreground="#A08050" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Stat: Đã cọc -->
            <Border Grid.Column="2" Background="#FBF0CC"
                    BorderBrush="#E8D9B5" BorderThickness="1"
                    Padding="16,8" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="lblDaCoc" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#B8892A" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                    <TextBlock Text="Đã cọc" FontSize="10"
                               Foreground="#A08050" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Stat: Hoàn thành -->
            <Border Grid.Column="3" Background="#EAF5EA"
                    BorderBrush="#C0DCC0" BorderThickness="1"
                    Padding="16,8" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="lblHoanThanh" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#3A7A3A" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                    <TextBlock Text="Hoàn thành" FontSize="10"
                               Foreground="#6A9A6A" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Stat: Đã hủy -->
            <Border Grid.Column="4" Background="#FFF0F0"
                    BorderBrush="#E8C0C0" BorderThickness="1"
                    Padding="16,8" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="lblDaHuy" Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#B85450" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                    <TextBlock Text="Đã hủy" FontSize="10"
                               Foreground="#B85450" HorizontalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ TOOLBAR: Live Search + Filter ═══ -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="#E8D9B5" BorderThickness="1"
                Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- Live search với Popup gợi ý -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <TextBox x:Name="txtSearch"
                             Style="{StaticResource TxtStyle}"
                             TextChanged="TxtSearch_TextChanged"
                             GotFocus="TxtSearch_GotFocus"
                             LostFocus="TxtSearch_LostFocus"/>
                    <!-- Placeholder text -->
                    <TextBlock x:Name="txtPlaceholder"
                               Text="🔍  Tìm tên khách hàng hoặc tên sự kiện..."
                               Foreground="#C0A878"
                               FontSize="12"
                               FontFamily="Montserrat, Segoe UI"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                    <!-- Popup gợi ý -->
                    <Popup x:Name="popupSuggest"
                           PlacementTarget="{Binding ElementName=txtSearch}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="White"
                                BorderBrush="#E8D9B5" BorderThickness="1"
                                MaxHeight="200">
                            <ListBox x:Name="lstSuggest"
                                     FontSize="12"
                                     FontFamily="Montserrat, Segoe UI"
                                     BorderThickness="0"
                                     SelectionChanged="LstSuggest_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FBF0CC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Filter trạng thái -->
                <ComboBox Grid.Column="1" x:Name="cboFilterTrangThai"
                          Style="{StaticResource CboStyle}"
                          Margin="0,0,10,0"
                          SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="-- Tất cả trạng thái --" IsSelected="True"/>
                    <ComboBoxItem Content="Đang đặt"/>
                    <ComboBoxItem Content="Đã cọc"/>
                    <ComboBoxItem Content="Hoàn thành"/>
                    <ComboBoxItem Content="Đã hủy"/>
                </ComboBox>

                <!-- Filter sảnh -->
                <ComboBox Grid.Column="2" x:Name="cboFilterSanh"
                          Style="{StaticResource CboStyle}"
                          Margin="0,0,10,0"
                          DisplayMemberPath="TenSanh"
                          SelectedValuePath="MaSanh"
                          SelectionChanged="Filter_Changed"/>

                <!-- Filter ngày -->
                <DatePicker Grid.Column="3" x:Name="dpFilter"
                            Height="32" FontSize="12"
                            SelectedDateChanged="Filter_Changed"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENT: DataGrid + Form ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0" x:Name="FormColumn"/>
            </Grid.ColumnDefinitions>

            <!-- DATAGRID -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E8D9B5" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" x:Name="dgDatSanh"
                              Style="{StaticResource DgStyle}"
                              ColumnHeaderStyle="{StaticResource GoldHeaderStyle}"
                              RowStyle="{StaticResource RowStyle}"
                              CellStyle="{StaticResource CellStyle}"
                              SelectionChanged="DgDatSanh_SelectionChanged">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#A08050"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Khách hàng" Binding="{Binding KhachHang.TenKhachHang}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#2A1F0A"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="SĐT" Binding="{Binding KhachHang.SoDienThoai}" Width="105">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#6B5430"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Sảnh" Binding="{Binding Sanh.TenSanh}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#C9A84C"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Sự kiện" Binding="{Binding TenSuKien}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#2A1F0A"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Ngày" Binding="{Binding NgayToChuc, StringFormat=dd/MM/yyyy}" Width="88">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#6B5430"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Giờ BD" Binding="{Binding GioBatDau}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#A08050"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Giờ KT" Binding="{Binding GioKetThuc}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#A08050"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Trạng thái badge -->
                            <DataGridTemplateColumn Header="Trạng thái" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="badgeBorder"
                                                Padding="8,3" Margin="10,8"
                                                HorizontalAlignment="Left"
                                                Background="#FBF0CC">
                                            <TextBlock x:Name="badgeText"
                                                       Text="{Binding TrangThai}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#C9A84C"
                                                       FontFamily="Montserrat, Segoe UI"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đang đặt">
                                                <Setter TargetName="badgeBorder" Property="Background" Value="#FBF0CC"/>
                                                <Setter TargetName="badgeText" Property="Foreground" Value="#C9A84C"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã cọc">
                                                <Setter TargetName="badgeBorder" Property="Background" Value="#FFF3E0"/>
                                                <Setter TargetName="badgeText" Property="Foreground" Value="#B8892A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                                                <Setter TargetName="badgeBorder" Property="Background" Value="#EAF5EA"/>
                                                <Setter TargetName="badgeText" Property="Foreground" Value="#3A7A3A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                <Setter TargetName="badgeBorder" Property="Background" Value="#FFF0F0"/>
                                                <Setter TargetName="badgeText" Property="Foreground" Value="#B85450"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Thao tác: chỉ giữ Đổi trạng thái + Xóa -->
                            <DataGridTemplateColumn Header="Thao tác" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0">
                                            <Button Content="Đổi trạng thái"
                                                    Style="{StaticResource BtnStatus}"
                                                    Height="28" Margin="0,0,6,0"
                                                    Tag="{Binding MaDat}"
                                                    Click="BtnDoiTrangThai_Click"/>
                                            <Button Content="Xóa"
                                                    Style="{StaticResource BtnDelete}"
                                                    Height="28"
                                                    Tag="{Binding MaDat}"
                                                    Click="BtnXoa_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Paging bar -->
                    <Border Grid.Row="1" Background="#F5EDD8"
                            BorderBrush="#E8D9B5" BorderThickness="0,1,0,0"
                            Padding="14,8">
                        <Grid>
                            <TextBlock x:Name="lblPaging" Text=""
                                       VerticalAlignment="Center"
                                       FontSize="11" Foreground="#A08050"
                                       FontFamily="Montserrat, Segoe UI"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnPrev" Content="◀" Width="28" Height="26"
                                        Background="White" BorderBrush="#E8D9B5" BorderThickness="1"
                                        Foreground="#A08050" Cursor="Hand"
                                        Click="BtnPrev_Click"/>
                                <TextBlock x:Name="lblPage"
                                           VerticalAlignment="Center"
                                           Margin="10,0" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#6B5430"
                                           FontFamily="Montserrat, Segoe UI"/>
                                <Button x:Name="btnNext" Content="▶" Width="28" Height="26"
                                        Background="White" BorderBrush="#E8D9B5" BorderThickness="1"
                                        Foreground="#A08050" Cursor="Hand"
                                        Click="BtnNext_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- FORM PANEL (giữ nguyên cho sửa nếu cần) -->
            <Border Grid.Column="1" x:Name="pnlForm" Background="White"
                    BorderBrush="#E8D9B5" BorderThickness="1"
                    Margin="12,0,0,0" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <Grid Margin="0,0,0,16">
                            <TextBlock x:Name="lblFormTitle" Text="Đổi trạng thái"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#2A1F0A"
                                       FontFamily="Playfair Display, Georgia, serif"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕" HorizontalAlignment="Right"
                                    Width="28" Height="28" BorderThickness="0"
                                    Background="#F5EDD8" Foreground="#A08050"
                                    Cursor="Hand" Click="BtnDongForm_Click"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#E8D9B5" Margin="0,0,0,16"/>

                        <TextBlock Text="Khách hàng *" Style="{StaticResource LblStyle}"/>
                        <ComboBox x:Name="cboKhachHang" Style="{StaticResource CboStyle}"
                                  DisplayMemberPath="TenKhachHang" SelectedValuePath="MaKhachHang"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Sảnh *" Style="{StaticResource LblStyle}"/>
                        <ComboBox x:Name="cboSanh" Style="{StaticResource CboStyle}"
                                  DisplayMemberPath="TenSanh" SelectedValuePath="MaSanh"
                                  Margin="0,0,0,12" SelectionChanged="CboSanh_Changed"/>

                        <TextBlock Text="Tên sự kiện *" Style="{StaticResource LblStyle}"/>
                        <TextBox x:Name="txtTenSuKien" Style="{StaticResource TxtStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Loại sự kiện *" Style="{StaticResource LblStyle}"/>
                        <ComboBox x:Name="cboLoaiSuKien" Style="{StaticResource CboStyle}"
                                  DisplayMemberPath="TenLoai" SelectedValuePath="MaLoai"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Menu *" Style="{StaticResource LblStyle}"/>
                        <ComboBox x:Name="cboMenu" Style="{StaticResource CboStyle}"
                                  DisplayMemberPath="TenMenu" SelectedValuePath="MaMenu"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Ngày tổ chức *" Style="{StaticResource LblStyle}"/>
                        <DatePicker x:Name="dpNgay" Height="32" FontSize="12"
                                    Margin="0,0,0,12" SelectedDateChanged="DpNgay_Changed"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Giờ bắt đầu *" Style="{StaticResource LblStyle}"/>
                                <ComboBox x:Name="cboGioBD" Style="{StaticResource CboStyle}"
                                          SelectionChanged="Gio_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Giờ kết thúc *" Style="{StaticResource LblStyle}"/>
                                <ComboBox x:Name="cboGioKT" Style="{StaticResource CboStyle}"
                                          SelectionChanged="Gio_Changed"/>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="pnlCanhBao" Background="#FFF0F0"
                                Padding="10,8" Margin="0,0,0,12" Visibility="Collapsed">
                            <TextBlock Text="⚠️ Sảnh đã có lịch trong khung giờ này!"
                                       Foreground="#B85450" FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Montserrat, Segoe UI"/>
                        </Border>

                        <TextBlock Text="Trạng thái *" Style="{StaticResource LblStyle}"/>
                        <ComboBox x:Name="cboTrangThai" Style="{StaticResource CboStyle}" Margin="0,0,0,20">
                            <ComboBoxItem Content="Đang đặt" IsSelected="True"/>
                            <ComboBoxItem Content="Đã cọc"/>
                            <ComboBoxItem Content="Hoàn thành"/>
                            <ComboBoxItem Content="Đã hủy"/>
                        </ComboBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="btnLuu" Content="Lưu"
                                    Background="{StaticResource GoldBtn}"
                                    Foreground="White" BorderThickness="0"
                                    Height="38" FontSize="12" FontWeight="SemiBold"
                                    FontFamily="Montserrat, Segoe UI" Cursor="Hand"
                                    Click="BtnLuu_Click"/>
                            <Button Grid.Column="2" Content="Hủy"
                                    Background="#F5EDD8" Foreground="#A08050"
                                    BorderThickness="0" Height="38"
                                    FontSize="12" FontFamily="Montserrat, Segoe UI"
                                    Cursor="Hand" Click="BtnDongForm_Click"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

    </DockPanel>
</UserControl>
