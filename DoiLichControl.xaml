<UserControl x:Class="DoAnCN_Net.UI.DoiLichControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Quan ly doi lich" FontSize="24" FontWeight="Bold" Foreground="#1A237E"/>
        </StackPanel>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch" Grid.Column="0"
                         Height="36" FontSize="14" Padding="8,0"
                         VerticalContentAlignment="Center"
                         TextChanged="TxtSearch_TextChanged"/>

                <ComboBox x:Name="cboFilter" Grid.Column="1" Margin="12,0,0,0"
                          Height="36" FontSize="13"
                          SelectionChanged="CboFilter_Changed">
                    <ComboBoxItem Content="Tat ca" IsSelected="True"/>
                    <ComboBoxItem Content="Dang dat"/>
                    <ComboBoxItem Content="Da xac nhan"/>
                    <ComboBoxItem Content="Hoan thanh"/>
                    <ComboBoxItem Content="Da huy"/>
                </ComboBox>

                <Button Grid.Column="2" Content="Lam moi" Margin="12,0,0,0"
                        Height="36" Padding="14,0"
                        Background="#E3F2FD" Foreground="#1565C0"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                        Click="BtnLamMoi_Click"/>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <Border Grid.Row="2" Background="White" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgDoiLich"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeight="42"
                          BorderThickness="0">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F0F4FF"/>
                            <Setter Property="Foreground" Value="#1A237E"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ma dat"      Binding="{Binding MaDat}"        Width="70"/>
                        <DataGridTextColumn Header="Khach hang"  Binding="{Binding TenKhachHang}" Width="160"/>
                        <DataGridTextColumn Header="So DT"       Binding="{Binding SoDienThoai}"  Width="120"/>
                        <DataGridTextColumn Header="Sanh"        Binding="{Binding TenSanh}"      Width="130"/>
                        <DataGridTextColumn Header="Su kien"     Binding="{Binding TenSuKien}"    Width="150"/>
                        <DataGridTextColumn Header="Ngay to chuc" Binding="{Binding NgayHienThi}" Width="110"/>
                        <DataGridTextColumn Header="Gio"         Binding="{Binding GioHienThi}"   Width="120"/>
                        <DataGridTextColumn Header="Menu"        Binding="{Binding TenMenu}"      Width="120"/>
                        <DataGridTextColumn Header="Trang thai"  Binding="{Binding TrangThai}"    Width="110"/>

                        <DataGridTemplateColumn Header="Thao tac" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Doi lich"
                                            Tag="{Binding}"
                                            Height="28" Padding="8,0"
                                            Background="#1565C0" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            FontSize="12" FontWeight="SemiBold"
                                            Click="BtnDoiLich_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#EEE" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tong: " Foreground="#888"/>
                        <TextBlock x:Name="txtTong" Text="0" FontWeight="SemiBold" Foreground="#1A237E"/>
                        <TextBlock Text=" don" Foreground="#888"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
