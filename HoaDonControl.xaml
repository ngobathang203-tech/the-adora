<UserControl x:Class="DoAnCN_Net.UI.HoaDonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F8F9FA"/>
            <Setter Property="Foreground"      Value="#555"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderBrush"     Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EDFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="5" Height="28" Background="#3d5af1" CornerRadius="3" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="Quản lý Hóa đơn" FontSize="22" FontWeight="Bold" Foreground="#1a1a2e"/>
                    <TextBlock Text="Danh sách hóa đơn &amp; thống kê doanh thu"
                               FontSize="12" Foreground="#999" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            <Button HorizontalAlignment="Right" Style="{StaticResource Btn}"
                    Background="#3d5af1" Foreground="White" Padding="16,9"
                    Click="btnAdd_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="＋" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Tạo hóa đơn" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- STATS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Tổng hóa đơn" FontSize="12" Foreground="#999"/>
                        <TextBlock x:Name="txtTong" Text="0"
                                   FontSize="28" FontWeight="Bold" Foreground="#1a1a2e" Margin="0,4,0,0"/>
                        <TextBlock Text="hóa đơn" FontSize="12" Foreground="#BBB"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="#EEF2FF"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="🧾" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Tổng doanh thu" FontSize="12" Foreground="#999"/>
                        <TextBlock x:Name="txtDoanhThu" Text="0"
                                   FontSize="20" FontWeight="Bold" Foreground="#3d5af1" Margin="0,4,0,0"/>
                        <TextBlock Text="đồng" FontSize="12" Foreground="#BBB"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="#EEF2FF"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="💰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Trung bình" FontSize="12" Foreground="#999"/>
                        <TextBlock x:Name="txtTrungBinh" Text="0"
                                   FontSize="20" FontWeight="Bold" Foreground="#2ecc71" Margin="0,4,0,0"/>
                        <TextBlock Text="đồng/hóa đơn" FontSize="12" Foreground="#BBB"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="#E8F8F0"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource Card}" Padding="20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Cao nhất" FontSize="12" Foreground="#999"/>
                        <TextBlock x:Name="txtCaoNhat" Text="0"
                                   FontSize="20" FontWeight="Bold" Foreground="#e94560" Margin="0,4,0,0"/>
                        <TextBlock Text="đồng" FontSize="12" Foreground="#BBB"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="#FFF0F3"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="📈" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- BỘ LỌC -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="7" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="13" Foreground="#555" VerticalAlignment="Center"
                                 TextChanged="txtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Từ ngày -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Từ ngày:" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="dpTuNgay" Width="130" Height="34"
                                SelectedDateChanged="dpTuNgay_SelectedDateChanged"/>
                </StackPanel>

                <!-- Đến ngày -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Đến ngày:" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="dpDenNgay" Width="130" Height="34"
                                SelectedDateChanged="dpDenNgay_SelectedDateChanged"/>
                </StackPanel>

                <!-- Xóa lọc -->
                <Button Grid.Column="6" Style="{StaticResource Btn}"
                        Background="#EEEEEE" Foreground="#666" Padding="12,8"
                        Content="↺ Xóa lọc" Click="btnClearFilter_Click"/>

                <!-- Xuất PDF -->
                <Button Grid.Column="8" Style="{StaticResource Btn}"
                        Background="#e94560" Foreground="White" Padding="12,8"
                        Content="📄 Xuất PDF" Click="btnXuatPDF_Click"/>
            </Grid>
        </Border>

        <!-- BẢNG DỮ LIỆU -->
        <Border Grid.Row="6" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="14,12"
                        BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource Btn}"
                                Background="#f39c12" Foreground="White"
                                Padding="12,8" Margin="0,0,8,0" Click="btnEdit_Click">
                            <TextBlock Text="✏  Sửa"/>
                        </Button>
                        <Button Style="{StaticResource Btn}"
                                Background="#e74c3c" Foreground="White"
                                Padding="12,8" Click="btnDelete_Click">
                            <TextBlock Text="🗑  Xóa"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- DataGrid -->
                <DataGrid x:Name="dgHoaDon" Grid.Row="1"
                          Background="White" BorderThickness="0"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0"
                          FontSize="13" RowHeight="44" ColumnHeaderHeight="40"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FAFBFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HD"      Binding="{Binding MaHoaDon}"              Width="80"/>
                        <DataGridTextColumn Header="Mã đặt"     Binding="{Binding MaDat}"                 Width="80"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}"          Width="*"/>
                        <DataGridTextColumn Header="Sự kiện"    Binding="{Binding TenSuKien}"             Width="*"/>
                        <DataGridTextColumn Header="Ngày lập"   Binding="{Binding NgayLapHienThi}"        Width="130"/>
                        <DataGridTemplateColumn Header="Tổng tiền" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="SemiBold" Foreground="#3d5af1"
                                               VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N0}đ">
                                                <Binding Path="TongTien"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
