<UserControl x:Class="DoAnCN_Net.KhachHangControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Text="QUẢN LÝ KHÁCH HÀNG" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Tìm kiếm cơ bản -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tìm kiếm:" Grid.Column="0" 
                           VerticalAlignment="Center" FontWeight="Bold"/>

                <ComboBox x:Name="cboKieuTimKiem" Grid.Column="1" 
                          SelectedIndex="0" Margin="5">
                    <ComboBoxItem Content="Tìm tất cả"/>
                    <ComboBoxItem Content="Theo họ"/>
                    <ComboBoxItem Content="Theo tên"/>
                    <ComboBoxItem Content="Theo họ và tên"/>
                    <ComboBoxItem Content="Theo số điện thoại"/>
                    <ComboBoxItem Content="Theo email"/>
                    
                </ComboBox>

                <TextBox x:Name="txtTimKiem" Grid.Column="2" 
                         Tag="Nhập từ khóa tìm kiếm..." 
                         Margin="5"
                         TextChanged="TxtTimKiem_TextChanged"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="btnTimKiem" Content="🔍 Tìm" 
                            Click="BtnTimKiem_Click" Width="80" Margin="5"
                            Background="#2196F3" Foreground="White"/>
                    <Button x:Name="btnXoaTimKiem" Content="🗑️ Xóa tìm" 
                            Click="BtnXoaTimKiem_Click" Width="80" Margin="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tìm kiếm nâng cao (Collapsible) -->
        <Expander Grid.Row="2" Header="Tìm kiếm nâng cao (Theo họ, tên, SĐT, email)" 
                  Margin="0,0,0,10" IsExpanded="False">
            <Border Background="#F9F9F9" Padding="10" CornerRadius="5" Margin="0,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Họ:" Grid.Row="0" Grid.Column="0" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtHo" Grid.Row="0" Grid.Column="1" Margin="5" 
                             ToolTip="Nhập họ (VD: Nguyễn, Trần, Lê...)"/>

                    <TextBlock Text="Tên:" Grid.Row="0" Grid.Column="2" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtTen" Grid.Row="0" Grid.Column="3" Margin="5"
                             ToolTip="Nhập tên (VD: An, Bình, Hoa...)"/>

                    <TextBlock Text="Số điện thoại:" Grid.Row="1" Grid.Column="0" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtSoDienThoaiTim" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Email:" Grid.Row="1" Grid.Column="2" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtEmailTim" Grid.Row="1" Grid.Column="3" Margin="5"/>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                                Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <Button x:Name="btnTimKiemNangCao" Content="🔍 Tìm nâng cao" 
                                Click="BtnTimKiemNangCao_Click" Width="120" Margin="5"
                                Background="#FF9800" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Expander>

        <!-- Form nhập liệu -->
        <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="THÔNG TIN KHÁCH HÀNG" 
                           FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tên khách hàng:" Grid.Row="0" Grid.Column="0" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtTenKhachHang" Grid.Row="0" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Số điện thoại:" Grid.Row="0" Grid.Column="2" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtSoDienThoai" Grid.Row="0" Grid.Column="3" Margin="5"/>

                    <TextBlock Text="Email:" Grid.Row="1" Grid.Column="0" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Mã KH:" Grid.Row="1" Grid.Column="2" 
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtMaKhachHang" Grid.Row="1" Grid.Column="3" 
                             Margin="5" IsReadOnly="True" Background="#F0F0F0"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnThem" Content="➕ Thêm mới" Click="BtnThem_Click" 
                            Width="100" Margin="5" Background="#4CAF50" Foreground="White"/>
                    <Button x:Name="btnSua" Content="✏️ Cập nhật" Click="BtnSua_Click" 
                            Width="100" Margin="5" Background="#2196F3" Foreground="White"/>
                    <Button x:Name="btnXoa" Content="🗑️ Xóa" Click="BtnXoa_Click" 
                            Width="100" Margin="5" Background="#F44336" Foreground="White"/>
                    <Button x:Name="btnLamMoi" Content="🔄 Làm mới" Click="BtnLamMoi_Click" 
                            Width="100" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Thông báo kết quả tìm kiếm -->
        <TextBlock x:Name="txtThongBaoTimKiem" Grid.Row="4" 
                   Foreground="Blue" FontSize="12"
                   Margin="0,0,0,5" Visibility="Collapsed"
                   HorizontalAlignment="Center"/>

        <!-- DataGrid hiển thị danh sách khách hàng -->
        <DataGrid x:Name="dgKhachHang" Grid.Row="5" 
                  AutoGenerateColumns="False" 
                  SelectionChanged="DgKhachHang_SelectionChanged"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKhachHang}" Width="80"/>
                <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKhachHang}" Width="250"/>
                <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTemplateColumn Header="Lịch sử đặt" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Xem lịch sử" 
                                    Click="BtnXemLichSu_Click"
                                    Tag="{Binding MaKhachHang}"
                                    Background="#FF9800"
                                    Foreground="White"
                                    Padding="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>