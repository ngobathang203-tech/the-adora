<UserControl x:Class="DoAnCN_Net.UI.KhuyenMaiControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA"
             FontFamily="Segoe UI">

	<UserControl.Resources>

		<!-- Colors -->
		<SolidColorBrush x:Key="AccentRed"    Color="#e94560"/>
		<SolidColorBrush x:Key="AccentBlue"   Color="#0f3460"/>
		<SolidColorBrush x:Key="CardBg"       Color="#FFFFFF"/>
		<SolidColorBrush x:Key="PageBg"       Color="#F4F6FA"/>
		<SolidColorBrush x:Key="BorderColor"  Color="#E2E8F0"/>
		<SolidColorBrush x:Key="TextPrimary"  Color="#1A202C"/>
		<SolidColorBrush x:Key="TextMuted"    Color="#718096"/>
		<SolidColorBrush x:Key="GreenBg"      Color="#F0FFF4"/>
		<SolidColorBrush x:Key="GreenText"    Color="#276749"/>
		<SolidColorBrush x:Key="RedBg"        Color="#FFF5F5"/>
		<SolidColorBrush x:Key="RedText"      Color="#9B2C2C"/>
		<SolidColorBrush x:Key="AmberBg"      Color="#FFFAF0"/>
		<SolidColorBrush x:Key="AmberText"    Color="#744210"/>
		<SolidColorBrush x:Key="BlueBg"       Color="#EBF8FF"/>
		<SolidColorBrush x:Key="BlueText"     Color="#2C5282"/>

		<!-- TextBox style -->
		<Style x:Key="InputStyle" TargetType="TextBox">
			<Setter Property="Height"            Value="38"/>
			<Setter Property="Padding"           Value="10,0"/>
			<Setter Property="FontSize"          Value="13"/>
			<Setter Property="Foreground"        Value="{StaticResource TextPrimary}"/>
			<Setter Property="Background"        Value="White"/>
			<Setter Property="BorderBrush"       Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness"   Value="1"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
							<ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter TargetName="bd" Property="BorderBrush"
                                        Value="{StaticResource AccentRed}"/>
								<Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ComboBox style -->
		<Style x:Key="ComboStyle" TargetType="ComboBox">
			<Setter Property="Height"          Value="38"/>
			<Setter Property="Padding"         Value="10,0"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
			<Setter Property="Background"      Value="White"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<!-- DatePicker style -->
		<Style x:Key="DateStyle" TargetType="DatePicker">
			<Setter Property="Height"      Value="38"/>
			<Setter Property="FontSize"    Value="13"/>
			<Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
			<Setter Property="Background"  Value="White"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<!-- Primary button -->
		<Style x:Key="BtnPrimary" TargetType="Button">
			<Setter Property="Height"           Value="38"/>
			<Setter Property="Padding"          Value="18,0"/>
			<Setter Property="FontSize"         Value="13"/>
			<Setter Property="FontWeight"       Value="SemiBold"/>
			<Setter Property="Foreground"       Value="White"/>
			<Setter Property="Background"       Value="{StaticResource AccentRed}"/>
			<Setter Property="BorderThickness"  Value="0"/>
			<Setter Property="Cursor"           Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#c73652"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#a52d46"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Secondary button -->
		<Style x:Key="BtnSecondary" TargetType="Button">
			<Setter Property="Height"          Value="38"/>
			<Setter Property="Padding"         Value="18,0"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
			<Setter Property="Background"      Value="White"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#F7FAFC"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#EDF2F7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Icon action button -->
		<Style x:Key="BtnIcon" TargetType="Button">
			<Setter Property="Width"           Value="32"/>
			<Setter Property="Height"          Value="32"/>
			<Setter Property="FontSize"        Value="15"/>
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Background" Value="#F0F4FF"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- DataGrid Column Header style -->
		<Style TargetType="DataGridColumnHeader">
			<Setter Property="Background"   Value="#F8FAFC"/>
			<Setter Property="Foreground"   Value="{StaticResource TextMuted}"/>
			<Setter Property="FontSize"     Value="12"/>
			<Setter Property="FontWeight"   Value="SemiBold"/>
			<Setter Property="Padding"      Value="12,10"/>
			<Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
		</Style>

		<!-- DataGrid Row style -->
		<Style TargetType="DataGridRow">
			<Setter Property="Background"  Value="White"/>
			<Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
			<Setter Property="FontSize"    Value="13"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#F8FAFC"/>
				</Trigger>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#FFF0F3"/>
					<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- DataGrid Cell style -->
		<Style TargetType="DataGridCell">
			<Setter Property="Padding"           Value="12,10"/>
			<Setter Property="BorderThickness"   Value="0"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="DataGridCell">
						<Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
							<ContentPresenter VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="Transparent"/>
					<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Header + Stats -->
			<RowDefinition Height="Auto"/>
			<!-- Toolbar / Filter -->
			<RowDefinition Height="*"/>
			<!-- Content area -->
		</Grid.RowDefinitions>

		<!-- ===== HEADER + STAT CARDS ===== -->
		<Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,20,28,20">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="14"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Title row -->
				<Grid Grid.Row="0">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<Border Width="36" Height="36" CornerRadius="8"
                                Background="#FFF0F3" Margin="0,0,12,0">
							<TextBlock Text="🎁" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<StackPanel>
							<TextBlock Text="Quản lý Khuyến mãi"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
							<TextBlock Text="Quản lý các chương trình ưu đãi và giảm giá"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
						</StackPanel>
					</StackPanel>

					<Button x:Name="btnAdd"
                            HorizontalAlignment="Right"
                            Style="{StaticResource BtnPrimary}"
                            Click="btnAdd_Click">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock Text="+" FontSize="18" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
							<TextBlock Text="Thêm khuyến mãi" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</Grid>

				<!-- Stat Cards -->
				<Grid Grid.Row="2">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="12"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="12"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="12"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<!-- Tổng số -->
					<Border Grid.Column="0" Background="#F8FAFC"
                            CornerRadius="10" Padding="16,14">
						<StackPanel>
							<TextBlock Text="Tổng khuyến mãi"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
							<TextBlock x:Name="txtTongSo"
                                       Text="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,4,0,0"/>
							<TextBlock Text="chương trình"
                                       FontSize="11" Foreground="{StaticResource TextMuted}"/>
						</StackPanel>
					</Border>

					<!-- Đang hoạt động -->
					<Border Grid.Column="2" Background="#F0FFF4"
                            CornerRadius="10" Padding="16,14">
						<StackPanel>
							<TextBlock Text="Đang hoạt động"
                                       FontSize="12" Foreground="#276749"/>
							<TextBlock x:Name="txtHoatDong"
                                       Text="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#276749"
                                       Margin="0,4,0,0"/>
							<TextBlock Text="chương trình"
                                       FontSize="11" Foreground="#276749"/>
						</StackPanel>
					</Border>

					<!-- Đã hết hạn -->
					<Border Grid.Column="4" Background="#FFF5F5"
                            CornerRadius="10" Padding="16,14">
						<StackPanel>
							<TextBlock Text="Đã hết hạn"
                                       FontSize="12" Foreground="#9B2C2C"/>
							<TextBlock x:Name="txtHetHan"
                                       Text="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#9B2C2C"
                                       Margin="0,4,0,0"/>
							<TextBlock Text="chương trình"
                                       FontSize="11" Foreground="#9B2C2C"/>
						</StackPanel>
					</Border>

					<!-- Tạm dừng -->
					<Border Grid.Column="6" Background="#FFFAF0"
                            CornerRadius="10" Padding="16,14">
						<StackPanel>
							<TextBlock Text="Tạm dừng"
                                       FontSize="12" Foreground="#744210"/>
							<TextBlock x:Name="txtTamDung"
                                       Text="0"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="#744210"
                                       Margin="0,4,0,0"/>
							<TextBlock Text="chương trình"
                                       FontSize="11" Foreground="#744210"/>
						</StackPanel>
					</Border>
				</Grid>
			</Grid>
		</Border>

		<!-- ===== TOOLBAR / FILTERS ===== -->
		<Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,12">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="12"/>
					<ColumnDefinition Width="160"/>
					<ColumnDefinition Width="12"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- Search box -->
				<Border Grid.Column="0"
                        Background="White"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="38"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0"
                                   Text="🔍" FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}"/>
						<TextBox Grid.Column="1"
                                 x:Name="txtSearch"
                                 Height="38"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="13"
                                 Foreground="{StaticResource TextPrimary}"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtSearch_TextChanged">
							<TextBox.Style>
								<Style TargetType="TextBox">
									<Setter Property="Template">
										<Setter.Value>
											<ControlTemplate TargetType="TextBox">
												<Grid>
													<TextBlock x:Name="placeholder"
                                                               Text="Tìm theo tên khuyến mãi..."
                                                               Foreground="#A0AEC0"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               Margin="2,0"
                                                               IsHitTestVisible="False"
                                                               Visibility="Collapsed"/>
													<ScrollViewer x:Name="PART_ContentHost"
                                                                  VerticalAlignment="Center"/>
												</Grid>
												<ControlTemplate.Triggers>
													<Trigger Property="Text" Value="">
														<Setter TargetName="placeholder"
                                                                Property="Visibility"
                                                                Value="Visible"/>
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
							</TextBox.Style>
						</TextBox>
					</Grid>
				</Border>

				<!-- Trạng thái filter -->
				<ComboBox Grid.Column="2"
                          x:Name="cboFilter"
                          Style="{StaticResource ComboStyle}"
                          SelectionChanged="cboFilter_SelectionChanged">
					<ComboBoxItem Content="Tất cả" IsSelected="True"/>
					<ComboBoxItem Content="Hoạt động"/>
					<ComboBoxItem Content="Tạm dừng"/>
					<ComboBoxItem Content="Hết hạn"/>
				</ComboBox>

				<!-- Refresh -->
				<Button Grid.Column="4"
                        x:Name="btnRefresh"
                        Style="{StaticResource BtnSecondary}"
                        Click="btnRefresh_Click">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="↻" FontSize="16" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
						<TextBlock Text="Làm mới" VerticalAlignment="Center"/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>

		<!-- ===== MAIN CONTENT AREA ===== -->
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition x:Name="FormColumn" Width="0"/>
			</Grid.ColumnDefinitions>

			<!-- TABLE -->
			<Border Grid.Column="0"
                    Background="White"
                    Margin="20,16,20,20"
                    CornerRadius="12"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<DataGrid x:Name="dgKhuyenMai"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFBFD"
                              SelectionChanged="dgKhuyenMai_SelectionChanged">

						<DataGrid.Columns>
							<!-- STT -->
							<DataGridTemplateColumn Header="#" Width="50">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding STT}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Tên khuyến mãi -->
							<DataGridTemplateColumn Header="Tên khuyến mãi" Width="*" MinWidth="180">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<StackPanel VerticalAlignment="Center">
											<TextBlock Text="{Binding TenKhuyenMai}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource TextPrimary}"/>
											<TextBlock Text="{Binding MoTa}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="280"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Giảm giá -->
							<DataGridTemplateColumn Header="Giảm giá" Width="120">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Border CornerRadius="12" Padding="10,4"
                                                Background="#FFF0F3"
                                                HorizontalAlignment="Left">
											<TextBlock Text="{Binding GiamGiaHienThi}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentRed}"/>
										</Border>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Ngày bắt đầu -->
							<DataGridTemplateColumn Header="Bắt đầu" Width="110">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding NgayBatDauHienThi}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Ngày kết thúc -->
							<DataGridTemplateColumn Header="Kết thúc" Width="110">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding NgayKetThucHienThi}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Trạng thái -->
							<DataGridTemplateColumn Header="Trạng thái" Width="120">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Border x:Name="statusBorder"
                                                CornerRadius="12"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Background="{Binding TrangThaiBg}">
											<TextBlock Text="{Binding TrangThai}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding TrangThaiColor}"/>
										</Border>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<!-- Actions -->
							<DataGridTemplateColumn Header="Thao tác" Width="90">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
											<Button Style="{StaticResource BtnIcon}"
                                                    ToolTip="Chỉnh sửa"
                                                    Click="btnEdit_Click"
                                                    Tag="{Binding MaKhuyenMai}">
												<TextBlock Text="✏️" FontSize="14"/>
											</Button>
											<Button Style="{StaticResource BtnIcon}"
                                                    ToolTip="Xóa"
                                                    Click="btnDelete_Click"
                                                    Tag="{Binding MaKhuyenMai}"
                                                    Margin="4,0,0,0">
												<TextBlock Text="🗑️" FontSize="14"/>
											</Button>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>

					<!-- Footer / Pagination info -->
					<Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,1,0,0"
                            Padding="16,10"
                            CornerRadius="0,0,12,12">
						<Grid>
							<TextBlock x:Name="txtRecordCount"
                                       Text="Hiển thị 0 bản ghi"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
						</Grid>
					</Border>
				</Grid>
			</Border>

			<!-- ===== FORM PANEL (SLIDE-IN) ===== -->
			<Border Grid.Column="1"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1,0,0,0"
                    x:Name="FormPanel">
				<Grid Margin="0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Form Header -->
					<Border Grid.Row="0"
                            Background="#1a1a2e"
                            Padding="20,16">
						<Grid>
							<StackPanel>
								<TextBlock x:Name="txtFormTitle"
                                           Text="Thêm khuyến mãi"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="White"/>
								<TextBlock Text="Điền thông tin bên dưới"
                                           FontSize="12" Foreground="#888888"
                                           Margin="0,2,0,0"/>
							</StackPanel>
							<Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="btnCloseForm_Click"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand" FontSize="18"
                                    Foreground="#888888"
                                    Content="✕"/>
						</Grid>
					</Border>

					<!-- Form Fields -->
					<ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,16">
						<StackPanel x:Name="FormFields" Margin="0,0,4,0">

							<!-- Tên khuyến mãi -->
							<TextBlock Text="Tên khuyến mãi *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
							<TextBox x:Name="txtTen"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,16"/>

							<!-- Loại giảm giá -->
							<TextBlock Text="Loại giảm giá *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
							<ComboBox x:Name="cboLoaiGiam"
                                      Style="{StaticResource ComboStyle}"
                                      SelectionChanged="cboLoaiGiam_SelectionChanged"
                                      Margin="0,0,0,12">
								<ComboBoxItem Content="% Phần trăm" IsSelected="True" Tag="PhanTram"/>
								<ComboBoxItem Content="Số tiền cố định" Tag="SoTien"/>
							</ComboBox>

							<!-- Giá trị giảm -->
							<TextBlock x:Name="lblGiaTri"
                                       Text="Phần trăm giảm (%) *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
							<TextBox x:Name="txtGiaTri"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,16"/>

							<!-- Ngày bắt đầu / kết thúc -->
							<Grid Margin="0,0,0,16">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="10"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="Ngày bắt đầu"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,6"/>
									<DatePicker x:Name="dpNgayBD"
                                                Style="{StaticResource DateStyle}"/>
								</StackPanel>
								<StackPanel Grid.Column="2">
									<TextBlock Text="Ngày kết thúc"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,6"/>
									<DatePicker x:Name="dpNgayKT"
                                                Style="{StaticResource DateStyle}"/>
								</StackPanel>
							</Grid>

							<!-- Trạng thái -->
							<TextBlock Text="Trạng thái"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
							<ComboBox x:Name="cboTrangThai"
                                      Style="{StaticResource ComboStyle}"
                                      Margin="0,0,0,16">
								<ComboBoxItem Content="Hoạt động" IsSelected="True"/>
								<ComboBoxItem Content="Tạm dừng"/>
							</ComboBox>

							<!-- Mô tả -->
							<TextBlock Text="Mô tả"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,6"/>
							<TextBox x:Name="txtMoTa"
                                     Height="80"
                                     Padding="10,8"
                                     FontSize="13"
                                     Foreground="{StaticResource TextPrimary}"
                                     Background="White"
                                     BorderBrush="{StaticResource BorderColor}"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,16">
								<TextBox.Template>
									<ControlTemplate TargetType="TextBox">
										<Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
											<ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"/>
										</Border>
									</ControlTemplate>
								</TextBox.Template>
							</TextBox>

							<!-- Validation message -->
							<Border x:Name="errBorder"
                                    Background="#FFF5F5"
                                    BorderBrush="#FC8181"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,10"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,12">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="⚠ " FontSize="14" Foreground="#C53030"/>
									<TextBlock x:Name="txtError"
                                               FontSize="12" Foreground="#C53030"
                                               TextWrapping="Wrap"/>
								</StackPanel>
							</Border>

						</StackPanel>
					</ScrollViewer>

					<!-- Form Buttons -->
					<Border Grid.Row="2"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,1,0,0"
                            Padding="20,14">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="10"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button Grid.Column="0"
                                    x:Name="btnCancel"
                                    Content="Hủy"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="btnCloseForm_Click"/>
							<Button Grid.Column="2"
                                    x:Name="btnSave"
                                    Content="Lưu"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="btnSave_Click"/>
						</Grid>
					</Border>
				</Grid>
			</Border>

		</Grid>
	</Grid>
</UserControl>
