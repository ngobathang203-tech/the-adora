<UserControl x:Class="DoAnCN_Net.LichSuDatTiec_Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDFAF5">

    <UserControl.Resources>

        <!-- ===== MÀU SẮC (đồng bộ toàn app) ===== -->
        <SolidColorBrush x:Key="GoldPrimary"   Color="#C9A84C"/>
        <SolidColorBrush x:Key="GoldTint"      Color="#FBF0CC"/>
        <SolidColorBrush x:Key="SurfaceWarm"   Color="#F5EDD8"/>
        <SolidColorBrush x:Key="CardBorder"    Color="#E8D9B5"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#2A1F0A"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#A08050"/>

        <LinearGradientBrush x:Key="GoldButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C9A84C" Offset="0"/>
            <GradientStop Color="#D4A940" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== STYLE: NÚT LỌC TRẠNG THÁI ===== -->
        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A08050"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FBF0CC"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#C9A84C"/>
                                <Setter Property="Foreground" Value="#C9A84C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FBF0CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT VÀNG (xem chi tiết) ===== -->
        <Style x:Key="GoldSmallButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GoldButtonGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT HỦY (outline đỏ nhạt) ===== -->
        <Style x:Key="CancelSmallButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B85450"/>
            <Setter Property="BorderBrush" Value="#E8C0C0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FFF0F0"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#B85450"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: Ô TÌM KIẾM ===== -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Foreground" Value="#2A1F0A"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#C9A84C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: HEADER CỘT DATAGRID ===== -->
        <Style x:Key="GoldHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F5EDD8"/>
            <Setter Property="Foreground" Value="#6B5430"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- ===== STYLE: ROW DATAGRID ===== -->
        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#F0E8D0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FBF0CC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDFAF5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== STYLE: CELL DATAGRID ===== -->
        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="#2A1F0A"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#2A1F0A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Margin="0,0,0,14" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#F5EDD8" Offset="0"/>
                    <GradientStop Color="#FBF0CC" Offset="0.5"/>
                    <GradientStop Color="#F5EDD8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#C9A84C" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness Bottom="1"/>
            </Border.BorderThickness>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="LỊCH SỬ ĐẶT TIỆC"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#2A1F0A"
                           FontFamily="Playfair Display, Georgia, serif"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="✦  QUẢN LÝ ĐƠN ĐẶT TIỆC CỦA BẠN  ✦"
                           FontSize="9" Foreground="#C9A84C"
                           FontFamily="Montserrat, Segoe UI"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== TÌM KIẾM + LỌC ===== -->
        <Border Grid.Row="1" Background="#FFFFFF"
                BorderBrush="#E8D9B5" BorderThickness="1"
                Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tìm kiếm -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tìm kiếm" FontSize="11" FontWeight="Medium"
                               Foreground="#6B5430" FontFamily="Montserrat, Segoe UI"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtSearch"
                             Style="{StaticResource SearchBoxStyle}"
                             Width="280"
                             TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>

                <!-- Tổng số đơn -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tổng đơn: " FontSize="11"
                               Foreground="#A08050" FontFamily="Montserrat, Segoe UI"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtTongDon" Text="0"
                               FontSize="13" FontWeight="Bold"
                               Foreground="#C9A84C" FontFamily="Montserrat, Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== LỌC TRẠNG THÁI ===== -->
        <Border Grid.Row="2" Background="#FDFAF5"
                Padding="0,0,0,10">
            <StackPanel x:Name="pnlFilterChip" Orientation="Horizontal">
                <TextBlock Text="Lọc: " FontSize="11" FontWeight="Medium"
                           Foreground="#6B5430" FontFamily="Montserrat, Segoe UI"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <RadioButton Content="Tất cả" GroupName="TrangThai"
                             Style="{StaticResource FilterChipStyle}"
                             IsChecked="True"
                             Checked="FilterTrangThai_Changed"/>
                <RadioButton Content="Chờ xác nhận" GroupName="TrangThai"
                             Style="{StaticResource FilterChipStyle}"
                             Checked="FilterTrangThai_Changed"/>
                <RadioButton Content="Đã xác nhận" GroupName="TrangThai"
                             Style="{StaticResource FilterChipStyle}"
                             Checked="FilterTrangThai_Changed"/>
                <RadioButton Content="Đã hủy" GroupName="TrangThai"
                             Style="{StaticResource FilterChipStyle}"
                             Checked="FilterTrangThai_Changed"/>
            </StackPanel>
        </Border>

        <!-- ===== DATAGRID ===== -->
        <Grid Grid.Row="3">

            <DataGrid x:Name="dgLichSu"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="46"
                      FontSize="12"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      BorderThickness="1"
                      BorderBrush="#E8D9B5"
                      Background="#FFFFFF"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#FDFAF5"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      CanUserReorderColumns="False"
                      ColumnHeaderStyle="{StaticResource GoldHeaderStyle}"
                      RowStyle="{StaticResource GridRowStyle}"
                      CellStyle="{StaticResource GridCellStyle}"
                      SelectionChanged="DgLichSu_SelectionChanged">

                <DataGrid.Columns>

                    <!-- Mã đặt -->
                    <DataGridTextColumn Header="Mã Đặt"
                                        Binding="{Binding MaDat}"
                                        Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#A08050"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tên sự kiện -->
                    <DataGridTextColumn Header="Tên Sự Kiện"
                                        Binding="{Binding TenSuKien}"
                                        Width="190">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#2A1F0A"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Sảnh -->
                    <DataGridTextColumn Header="Sảnh"
                                        Binding="{Binding Sanh.TenSanh}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#C9A84C"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Ngày tổ chức -->
                    <DataGridTextColumn Header="Ngày Tổ Chức"
                                        Binding="{Binding NgayToChuc, StringFormat=dd/MM/yyyy}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#6B5430"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Giờ bắt đầu -->
                    <DataGridTextColumn Header="Giờ Bắt Đầu"
                                        Binding="{Binding GioBatDau}"
                                        Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#6B5430"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Giờ kết thúc -->
                    <DataGridTextColumn Header="Giờ Kết Thúc"
                                        Binding="{Binding GioKetThuc}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#6B5430"/>
                                <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
                                <Setter Property="Margin" Value="12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Trạng thái (badge màu) -->
                    <DataGridTemplateColumn Header="Trạng Thái" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badgeBorder"
                                        Padding="8,3" Margin="10,8"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FBF0CC"/>
                                    </Border.Background>
                                    <TextBlock x:Name="badgeText"
                                               Text="{Binding TrangThai}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#C9A84C"
                                               FontFamily="Montserrat, Segoe UI"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="Đã xác nhận">
                                        <Setter TargetName="badgeBorder" Property="Background" Value="#EAF5EA"/>
                                        <Setter TargetName="badgeText" Property="Foreground" Value="#3A7A3A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                        <Setter TargetName="badgeBorder" Property="Background" Value="#FFF0F0"/>
                                        <Setter TargetName="badgeText" Property="Foreground" Value="#B85450"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="Chờ xác nhận">
                                        <Setter TargetName="badgeBorder" Property="Background" Value="#FBF0CC"/>
                                        <Setter TargetName="badgeText" Property="Foreground" Value="#C9A84C"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Cột hành động: Xem chi tiết + Hủy -->
                    <DataGridTemplateColumn Header="Hành Động" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="8,0">
                                    <Button Content="Chi tiết"
                                            Style="{StaticResource GoldSmallButton}"
                                            Margin="0,0,6,0"
                                            Tag="{Binding MaDat}"
                                            Click="BtnChiTiet_Click"/>
                                    <Button Content="Hủy đặt"
                                            Tag="{Binding MaDat}"
                                            Click="BtnHuy_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource CancelSmallButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Đã hủy">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThai}" Value="Đã xác nhận">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state -->
            <StackPanel x:Name="pnlEmpty"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="📋"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Bạn chưa có đơn đặt tiệc nào"
                           FontSize="15" FontWeight="Medium"
                           Foreground="#6B5430"
                           FontFamily="Montserrat, Segoe UI"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Hãy khám phá các sảnh tiệc và đặt ngay hôm nay!"
                           FontSize="12" Foreground="#A08050"
                           FontFamily="Montserrat, Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
