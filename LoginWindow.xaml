<Window x:Class="DoAnCN_Net.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Adora - Login"
        Height="520"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Opacity="0">

    <Window.Resources>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 8"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Background" Value="#F9F9F9"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 8"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Background" Value="#F9F9F9"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#C6A75E"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#C6A75E"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6"/>
                    <DoubleAnimation Storyboard.TargetName="trans"
                                     Storyboard.TargetProperty="Y"
                                     From="60" To="0" Duration="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform x:Name="trans" Y="50"/>
        </Grid.RenderTransform>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E293B" Offset="0.5"/>
                <GradientStop Color="#C6A75E" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Rectangle Fill="#66000000"/>

        <!-- LEFT -->
        <Grid Width="400" HorizontalAlignment="Left">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="THE ADORA"
                           Foreground="#E6C77A"
                           FontSize="36"
                           FontWeight="Bold"/>
                <TextBlock Text="Conference &amp; Banquet Center"
                           Foreground="#DDDDDD"
                           FontSize="14"
                           Margin="0 10 0 0"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT -->
        <Grid Width="340"
              VerticalAlignment="Center"
              HorizontalAlignment="Right"
              Margin="0 0 60 0">

            <!-- CARD ĐĂNG NHẬP -->
            <Border x:Name="CardLogin"
                    Background="#CCFFFFFF"
                    CornerRadius="15"
                    Padding="30"
                    Visibility="Visible">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Đăng Nhập"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0 0 0 16"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Tên đăng nhập" FontSize="12" Foreground="#555" Margin="0 0 0 2"/>
                    <TextBox x:Name="txtUser" Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Mật khẩu (Số điện thoại)" FontSize="12" Foreground="#555" Margin="0 0 0 2"/>

                    <!-- Wrapper chứa PasswordBox + TextBox + icon mắt -->
                    <Grid Margin="0 8">
                        <PasswordBox x:Name="txtPass"
                 Height="42"
                 Padding="10 5"
                 Background="#F9F9F9"
                 BorderBrush="#DDD"
                 BorderThickness="1"
                 VerticalContentAlignment="Center"/>

                        <!-- TextBox hiện mật khẩu dạng text, ẩn mặc định -->
                        <TextBox x:Name="txtPassVisible"
             Height="42"
             Padding="10 5"
             Background="#F9F9F9"
             BorderBrush="#DDD"
             BorderThickness="1"
             VerticalContentAlignment="Center"
             Visibility="Collapsed"/>

                        <!-- Icon mắt -->
                        <Button x:Name="btnTogglePass"
            Width="36" Height="36"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0 0 4 0"
            Background="Transparent"
            BorderThickness="0"
            Cursor="Hand"
            Click="TogglePassword_Click"
            Content="👁"
            FontSize="16"/>
                    </Grid>

                    <Button Content="ĐĂNG NHẬP"
                            Style="{StaticResource GoldButton}"
                            Margin="0 16 0 0"
                            Click="Login_Click"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0 12 0 0">
                        <TextBlock Text="Chưa có tài khoản? "
                                   Foreground="#666" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Content="Đăng ký ngay"
                                Style="{StaticResource LinkButton}"
                                Click="ShowRegister_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- CARD ĐĂNG KÝ -->
            <Border x:Name="CardRegister"
                    Background="#CCFFFFFF"
                    CornerRadius="15"
                    Padding="30"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Tạo Tài Khoản"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0 0 0 14"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Họ và tên" FontSize="12" Foreground="#555" Margin="0 0 0 2"/>
                    <TextBox x:Name="txtRegName" Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Email" FontSize="12" Foreground="#555" Margin="0 0 0 2"/>
                    <TextBox x:Name="txtRegEmail" Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Số điện thoại (dùng để đăng nhập)" FontSize="12" Foreground="#555" Margin="0 0 0 2"/>
                    <TextBox x:Name="txtRegPhone" Style="{StaticResource ModernTextBox}"/>

                    <Button Content="ĐĂNG KÝ"
                            Style="{StaticResource GoldButton}"
                            Margin="0 14 0 0"
                            Click="Register_Click"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0 10 0 0">
                        <TextBlock Text="Đã có tài khoản? "
                                   Foreground="#666" FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Content="Đăng nhập"
                                Style="{StaticResource LinkButton}"
                                Click="ShowLogin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>