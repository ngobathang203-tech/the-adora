<UserControl x:Class="DoAnCN_Net.SanhControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cnv="clr-namespace:DoAnCN_Net"
             Background="#0F1117">

    <UserControl.Resources>
        <cnv:StringToImageConverters x:Key="StringToImageConverters"/>

        <SolidColorBrush x:Key="BgBase"       Color="#0F1117"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgInput"      Color="#23263A"/>
        <SolidColorBrush x:Key="AccentGold"   Color="#F0C060"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#4A9EFF"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#34D399"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#F87171"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FB923C"/>
        <SolidColorBrush x:Key="Border1"      Color="#2E3250"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecond"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#475569"/>

        <LinearGradientBrush x:Key="GoldGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0C060" Offset="0"/>
            <GradientStop Color="#D4883A" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BlueGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4A9EFF" Offset="0"/>
            <GradientStop Color="#2563EB" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GreenGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#34D399" Offset="0"/>
            <GradientStop Color="#059669" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RedGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F87171" Offset="0"/>
            <GradientStop Color="#DC2626" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OrangeGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FB923C" Offset="0"/>
            <GradientStop Color="#EA580C" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SlateGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#64748B" Offset="0"/>
            <GradientStop Color="#334155" Offset="1"/>
        </LinearGradientBrush>

        <!-- ══ LABEL ══ -->
        <Style x:Key="LblField" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- ══ TEXTBOX ══ -->
        <Style x:Key="TxtField" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#23263A"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3250"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#F0C060"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F0C060"/>
                                <Setter TargetName="bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#4A5580"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ COMBOBOX ITEM ══ -->
        <Style x:Key="CboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#252A45"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#2E3250"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="dot"
                                         Grid.Column="0"
                                         Width="6" Height="6"
                                         Fill="#F0C060"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         Opacity="0"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#374170"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="dot" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#2E3A6E"/>
                                <Setter Property="Foreground" Value="#F0C060"/>
                                <Setter TargetName="dot" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ COMBOBOX ══ -->
        <Style x:Key="CboField" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#23263A"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#2E3250"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- PART_ToggleButton: tên bắt buộc WPF dùng để bắt click mở dropdown -->
                            <ToggleButton x:Name="PART_ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen,
                                                      Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="#23263A"
                                                BorderBrush="#2E3250"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1"
                                                           Text="▾"
                                                           Foreground="#64748B"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#F0C060"/>
                                                <Setter TargetName="bd" Property="Background" Value="#2A2E45"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#4A5580"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- PART_ContentSite: hiển thị item đang chọn, không bắt click -->
                            <ContentPresenter x:Name="PART_ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <!-- Popup nằm ngoài visual tree, không bị clip bởi bất kỳ container nào -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth,
                                               RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="220"
                                      SnapsToDevicePixels="True">
                                    <Border Background="#252A45"
                                            BorderBrush="#4A5580"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter SnapsToDevicePixels="True"
                                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ ACTION BUTTON ══ -->
        <Style x:Key="BtnAction" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ CARD BUTTON ══ -->
        <Style x:Key="BtnCard" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════
             ROW 0 — HEADER
        ══════════════════════════════════ -->
        <Border Grid.Row="0" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Rectangle Width="36" Height="3" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F0C060" Offset="0"/>
                                <GradientStop Color="#D4883A" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Text="Quản lý Sảnh Tiệc"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9"
                               FontFamily="Georgia, 'Times New Roman', serif"/>
                    <TextBlock x:Name="lblSubtitle"
                               Text="0 sảnh đang hoạt động"
                               FontSize="12" Foreground="#64748B"
                               FontFamily="Segoe UI, sans-serif"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A1D27"
                            BorderBrush="#2E3250" BorderThickness="1"
                            CornerRadius="8" Padding="16,10" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock x:Name="lblTongSanh" Text="0"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#F0C060" HorizontalAlignment="Center"
                                       FontFamily="Segoe UI, sans-serif"/>
                            <TextBlock Text="Tổng sảnh" FontSize="10" Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════
             ROW 1 — FORM CARD
             Panel.ZIndex="50" + KHÔNG có DropShadowEffect
        ══════════════════════════════════ -->
        <Border Grid.Row="1"
                Panel.ZIndex="50"
                Background="#1A1D27"
                BorderBrush="#2E3250" BorderThickness="1"
                CornerRadius="12" Padding="24,20"
                Margin="0,0,0,16">
            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <Border Width="4" CornerRadius="2"
                            Background="{StaticResource GoldGrad}"
                            Margin="0,0,10,0"/>
                    <TextBlock Text="THÔNG TIN SẢNH"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#F0C060"
                               FontFamily="Consolas, Courier New"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 1: Tên / Sức chứa / Giá thuê -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TÊN SẢNH" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtTenSanh" Style="{StaticResource TxtField}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SỨC CHỨA (NGƯỜI)" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtSucChua" Style="{StaticResource TxtField}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="GIÁ THUÊ (VND)" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtGiaThue" Style="{StaticResource TxtField}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Chi nhánh / Hình ảnh
                     Panel.ZIndex="999" → Popup luôn nổi lên trên tất cả -->
                <Grid Margin="0,14,0,0" Panel.ZIndex="999">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CHI NHÁNH" Style="{StaticResource LblField}"/>
                        <ComboBox x:Name="cboChiNhanh"
                                  Style="{StaticResource CboField}"
                                  SelectedValuePath="MaChiNhanh">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TenChiNhanh}"
                                               Foreground="#F1F5F9"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI, sans-serif"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ĐƯỜNG DẪN HÌNH ẢNH" Style="{StaticResource LblField}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtHinhAnh"
                                     Grid.Column="0"
                                     Style="{StaticResource TxtField}"/>
                            <Button Grid.Column="2"
                                    x:Name="btnChonAnh"
                                    Content="📁  Chọn ảnh"
                                    Style="{StaticResource BtnAction}"
                                    Background="{StaticResource BlueGrad}"
                                    Height="36"
                                    Click="BtnChonAnh_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="#2E3250" Margin="0,20,0,16"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnLamMoi"
                            Content="↺  Làm mới"
                            Style="{StaticResource BtnAction}"
                            Background="{StaticResource SlateGrad}"
                            Margin="0,0,8,0"
                            Click="BtnLamMoi_Click"/>
                    <Button x:Name="btnXoa"
                            Content="🗑  Xóa"
                            Style="{StaticResource BtnAction}"
                            Background="{StaticResource RedGrad}"
                            Margin="0,0,8,0"
                            Click="BtnXoa_Click"/>
                    <Button x:Name="btnSua"
                            Content="✏  Cập nhật"
                            Style="{StaticResource BtnAction}"
                            Background="{StaticResource OrangeGrad}"
                            Margin="0,0,8,0"
                            Click="BtnSua_Click"/>
                    <Button x:Name="btnThem"
                            Content="＋  Thêm mới"
                            Style="{StaticResource BtnAction}"
                            Background="{StaticResource GreenGrad}"
                            Click="BtnThem_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════
             ROW 2 — SEARCH BAR
             KHÔNG có DropShadowEffect
        ══════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#1A1D27"
                BorderBrush="#2E3250" BorderThickness="1"
                CornerRadius="10" Padding="16,12"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#23263A"
                        BorderBrush="#2E3250" BorderThickness="1"
                        CornerRadius="7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,8,0" Foreground="#64748B"/>
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 Foreground="#F1F5F9"
                                 BorderThickness="0"
                                 FontSize="12"
                                 FontFamily="Segoe UI, sans-serif"
                                 VerticalContentAlignment="Center"
                                 Height="36"
                                 Padding="0,0,12,0"
                                 CaretBrush="#F0C060"
                                 TextChanged="TxtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <Button Grid.Column="2"
                        x:Name="btnSearch"
                        Content="Tìm kiếm"
                        Style="{StaticResource BtnAction}"
                        Background="{StaticResource GoldGrad}"
                        Foreground="#1A1D27"
                        Click="BtnSearch_Click"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════
             ROW 3 — CARD GRID
        ══════════════════════════════════ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="5"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ScrollViewer.Resources>

            <ItemsControl x:Name="icSanh">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- CARD — KHÔNG có DropShadowEffect -->
                        <Border Width="262" Margin="0,0,16,16"
                                Background="#1A1D27"
                                BorderBrush="#2E3250" BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>

                                <Border CornerRadius="12,12,0,0"
                                        ClipToBounds="True"
                                        Height="155">
                                    <Grid>
                                        <Image Stretch="UniformToFill"
                                               Source="{Binding HinhAnh, Converter={StaticResource StringToImageConverters}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                        <Rectangle VerticalAlignment="Bottom" Height="60">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#001A1D27" Offset="0"/>
                                                    <GradientStop Color="#CC1A1D27" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,10,10,0"
                                                Background="#CC0F1117"
                                                BorderBrush="#F0C06040" BorderThickness="1"
                                                CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="{Binding TenChiNhanh}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="#F0C060"
                                                       FontFamily="Segoe UI, sans-serif"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="14,12,14,14">

                                    <TextBlock Text="{Binding TenSanh}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#F1F5F9"
                                               FontFamily="Georgia, serif"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding SucChua}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#4A9EFF"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI, sans-serif"/>
                                            <TextBlock Text="người" FontSize="10"
                                                       Foreground="#475569"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI, sans-serif"/>
                                        </StackPanel>

                                        <Rectangle Grid.Column="1" Fill="#2E3250"/>

                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding GiaThue, StringFormat={}{0:N0}}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#F0C060"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI, sans-serif"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="VND / buổi" FontSize="10"
                                                       Foreground="#475569"
                                                       HorizontalAlignment="Center"
                                                       FontFamily="Segoe UI, sans-serif"/>
                                        </StackPanel>
                                    </Grid>

                                    <Rectangle Height="1" Fill="#2E3250" Margin="0,0,0,12"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Content="Chi tiết"
                                                Style="{StaticResource BtnCard}"
                                                Background="{StaticResource BlueGrad}"
                                                Click="BtnChiTiet_Click"/>
