<Window x:Class="DoAnCN_Net.TrangChu_User"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Adora Center - Trang Chủ"
        Height="750"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#FDFAF5"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ===== MÀU SẮC LUXURY GOLD - LIGHT EDITION ===== -->
        <SolidColorBrush x:Key="GoldPrimary"   Color="#C9A84C"/>
        <SolidColorBrush x:Key="GoldLight"     Color="#D4A940"/>
        <SolidColorBrush x:Key="GoldPale"      Color="#F0D080"/>
        <SolidColorBrush x:Key="GoldTint"      Color="#FBF0CC"/>
        <SolidColorBrush x:Key="DarkBase"      Color="#FDFAF5"/>
        <SolidColorBrush x:Key="DarkSurface"   Color="#F5EDD8"/>
        <SolidColorBrush x:Key="DarkCard"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DarkBorder"    Color="#E8D9B5"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#2A1F0A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B5430"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#A08050"/>

        <!-- Gradient nền hero -->
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FDFAF5" Offset="0"/>
            <GradientStop Color="#F5EDD8" Offset="0.4"/>
            <GradientStop Color="#F0E0B0" Offset="0.7"/>
            <GradientStop Color="#FDFAF5" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient nút vàng -->
        <LinearGradientBrush x:Key="GoldButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C9A84C" Offset="0"/>
            <GradientStop Color="#D4A940" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient header -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FDFAF5" Offset="0"/>
            <GradientStop Color="#F5EDD8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient card top -->
        <LinearGradientBrush x:Key="CardTopGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FBF0CC" Offset="0"/>
            <GradientStop Color="#F5EDD8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient logo icon -->
        <LinearGradientBrush x:Key="LogoGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C9A84C" Offset="0"/>
            <GradientStop Color="#D4A940" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== STYLE: NÚT TITLEBAR ===== -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#A08050"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F0E0B0"/>
                                <Setter Property="Foreground" Value="#C9A84C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT NAV ===== -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#A08050"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bg" Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Rectangle x:Name="underline" Height="1" Width="20"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                       Fill="#C9A84C" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C9A84C"/>
                                <Setter TargetName="underline" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT VÀNG SOLID (CTA chính) ===== -->
        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GoldButtonGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== STYLE: NÚT GHOST (viền vàng) ===== -->
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9A84C"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#C9A84C"/>
                                <Setter TargetName="bg" Property="Background" Value="#FBF0CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT CTA CARD (outline vàng) ===== -->
        <Style x:Key="CardCtaButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FBF0CC"/>
            <Setter Property="Foreground" Value="#C9A84C"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="14,10,14,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource GoldButtonGradient}"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: NÚT ĐĂNG XUẤT ===== -->
        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A08050"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat, Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#C9A84C"/>
                                <Setter TargetName="bg" Property="Background" Value="#FBF0CC"/>
                                <Setter Property="Foreground" Value="#C9A84C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== STYLE: CARD KHUYẾN MÃI ===== -->
        <Style x:Key="PromoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E8D9B5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Background="#FDFAF5">

        <!-- ===== TITLEBAR ===== -->
        <Border Height="28" VerticalAlignment="Top" Background="#F5EDD8"
                BorderBrush="#E8D9B5" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="✦" FontSize="10" Foreground="#C9A84C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="ADORA CENTER" FontSize="10" FontWeight="SemiBold"
                               Foreground="#C9A84C" VerticalAlignment="Center"
                               FontFamily="Montserrat, Segoe UI"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="─" Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeWindow_Click"/>
                    <Button Content="□" Style="{StaticResource TitleBarButtonStyle}" Click="MaximizeWindow_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="CloseWindow_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== NỘI DUNG CHÍNH ===== -->
        <Grid Margin="0,28,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    BorderBrush="#E8D9B5" BorderThickness="0,0,0,1"
                    Padding="28,12">
                <DockPanel>

                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <Border Width="36" Height="36" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C9A84C" Offset="0"/>
                                    <GradientStop Color="#D4A940" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="A" FontSize="20" FontWeight="Bold"
                                       Foreground="#FFFFFF" FontFamily="Playfair Display, Georgia, serif"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="A D O R A  C E N T E R"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#C9A84C"
                                       FontFamily="Playfair Display, Georgia, serif"/>
                            <TextBlock Text="LUXURY EVENT SPACE"
                                       FontSize="8" Foreground="#A08050"
                                       FontFamily="Montserrat, Segoe UI"
                                       FontWeight="Light" Margin="1,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Logout + User -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" DockPanel.Dock="Right" Margin="0,0,0,0">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock x:Name="txtUserName" Text="Nguyễn Văn A"
                                       FontSize="12" Foreground="#2A1F0A"
                                       FontFamily="Montserrat, Segoe UI" FontWeight="Medium"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="KHÁCH HÀNG"
                                       FontSize="8" Foreground="#A08050"
                                       FontFamily="Montserrat, Segoe UI"
                                       HorizontalAlignment="Right" Margin="0,1,0,0"/>
                        </StackPanel>
                        <Border Width="32" Height="32" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C9A84C" Offset="0"/>
                                    <GradientStop Color="#D4A940" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Clip>
                                <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                            </Border.Clip>
                            <TextBlock Text="N" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#FFFFFF" FontFamily="Montserrat, Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Button Content="THOÁT" Style="{StaticResource LogoutButtonStyle}"
                                Click="Logout_Click"/>
                    </StackPanel>

                    <!-- Nav -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="TRANG CHỦ" Style="{StaticResource NavButtonStyle}" Click="OpenTrangChu_Click"/>
                        <Button Content="SẢNH TIỆC" Style="{StaticResource NavButtonStyle}" Click="OpenSanhList_Click"/>
                        <Button Content="THỰC ĐƠN"  Style="{StaticResource NavButtonStyle}" Click="OpenMenuList_Click"/>
                        <Button Content="ĐẶT TIỆC"  Style="{StaticResource NavButtonStyle}" Click="OpenBooking_Click"/>
                        <Button Content="LỊCH SỬ"   Style="{StaticResource NavButtonStyle}" Click="OpenBookingHistory_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== TRANG CHỦ + USERCONTROL ===== -->
            <Grid Grid.Row="1">

                <!-- Trang chủ mặc định -->
                <Grid x:Name="gridTrangChu">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="230"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ===== HERO BANNER ===== -->
                    <Grid Grid.Row="0" Margin="0,0,0,0">
                        <!-- Nền gradient -->
                        <Border Background="{StaticResource HeroGradient}"
                                BorderBrush="#EEE0C0" BorderThickness="0,1,0,1"/>

                        <!-- Đường viền vàng top -->
                        <Rectangle Height="1" VerticalAlignment="Top">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#C9A84C" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Đường viền vàng bottom -->
                        <Rectangle Height="1" VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#C9A84C" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Vòng trang trí ornament -->
                        <Ellipse Width="300" Height="300"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Margin="0,0,-60,0"
                                 Stroke="#EEE0C0" StrokeThickness="1" Fill="Transparent" Opacity="0.6"/>
                        <Ellipse Width="200" Height="200"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Margin="0,0,20,0"
                                 Stroke="#E8D9B5" StrokeThickness="1" Fill="Transparent" Opacity="0.5"/>

                        <!-- Layout: nội dung trái + badge phải -->
                        <Grid Margin="40,0,40,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nội dung hero trái -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <!-- Eyebrow -->
                                <TextBlock Text="✦  ƯU ĐÃI ĐẶC BIỆT THÁNG 5  ✦"
                                           FontSize="9" FontWeight="Medium"
                                           Foreground="#C9A84C"
                                           FontFamily="Montserrat, Segoe UI"
                                           Margin="0,0,0,10"/>

                                <!-- Tiêu đề chính -->
                                <TextBlock FontFamily="Playfair Display, Georgia, serif"
                                           FontSize="36" FontWeight="Bold"
                                           Foreground="#2A1F0A" LineHeight="44">
                                    <Run Text="Kiến Tạo"/>
                                    <LineBreak/>
                                    <Run Text="Khoảnh Khắc "/>
                                    <Run Text="Vàng" Foreground="#C9A84C" FontStyle="Italic"/>
                                </TextBlock>

                                <!-- Mô tả -->
                                <TextBlock Text="Không gian tiệc cưới sang trọng bậc nhất — nơi mỗi khoảnh khắc đều trở thành ký ức trường tồn."
                                           FontSize="11" Foreground="#A08050"
                                           FontFamily="Montserrat, Segoe UI" FontWeight="Light"
                                           Margin="0,12,0,20" TextWrapping="Wrap" MaxWidth="500"
                                           LineHeight="18"/>

                                <!-- Nút hành động -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="ĐẶT TIỆC NGAY"
                                            Style="{StaticResource GoldButtonStyle}"
                                            Height="38" Padding="24,0"
                                            Click="OpenSanhList_Click"/>
                                    <Button Content="XEM SẢNH TIỆC"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Height="38" Padding="20,0" Margin="12,0,0,0"
                                            Click="OpenSanhList_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Badge tròn góc phải -->
                            <Border Grid.Column="1" Width="88" Height="88"
                                    VerticalAlignment="Center" Margin="30,0,20,0"
                                    BorderBrush="#C9A84C" BorderThickness="1">
                                <Border.Clip>
                                    <EllipseGeometry Center="44,44" RadiusX="44" RadiusY="44"/>
                                </Border.Clip>
                                <Border BorderBrush="#E8D9B5" BorderThickness="1" Margin="5">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FBF0CC"/>
                                    </Border.Background>
                                    <Border.Clip>
                                        <EllipseGeometry Center="39,39" RadiusX="39" RadiusY="39"/>
                                    </Border.Clip>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="20"
                                                       FontFamily="Playfair Display, Georgia, serif"
                                                       FontSize="30" FontWeight="Bold"
                                                       Foreground="#C9A84C" VerticalAlignment="Center"/>
                                            <TextBlock Text="%"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#D4A940" VerticalAlignment="Top"
                                                       Margin="1,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="ƯU ĐÃI"
                                                   FontSize="7" Foreground="#A08050"
                                                   FontFamily="Montserrat, Segoe UI"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ===== TIÊU ĐỀ SECTION ===== -->
                    <Grid Grid.Row="1" Margin="26,14,26,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Khuyến Mãi Nổi Bật"
                                       FontFamily="Playfair Display, Georgia, serif"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="#2A1F0A"/>
                            <TextBlock Text="  ✦  ƯU ĐÃI CÓ HẠN"
                                       FontSize="9" Foreground="#C9A84C"
                                       FontFamily="Montserrat, Segoe UI" FontWeight="Medium"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button Content="Xem tất cả  →"
                                Style="{StaticResource NavButtonStyle}"
                                HorizontalAlignment="Right"
                                Click="ViewAllPromotions_Click"/>
                    </Grid>

                    <!-- ===== DANH SÁCH KHUYẾN MÃI ===== -->
                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="22,0,22,20">
                        <ItemsControl x:Name="ItemsKhuyenMai">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource PromoCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Top: hiển thị % giảm -->
                                            <Border Grid.Row="0" Padding="0,22,0,16">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FBF0CC" Offset="0"/>
                                                        <GradientStop Color="#F5EDD8" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>

                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding GiaTriHienThi}"
                                                               FontFamily="Playfair Display, Georgia, serif"
                                                               FontSize="42" FontWeight="Bold"
                                                               Foreground="#C9A84C"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding BadgeText}"
                                                               FontSize="9"
                                                               FontFamily="Montserrat, Segoe UI"
                                                               Foreground="#A08050"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Badge "CÓ HẠN" -->
                                            <Canvas Grid.Row="0" Height="0">
                                                <Border Background="#D4A940" Padding="6,3"
                                                        Canvas.Right="10" Canvas.Top="10">
                                                    <TextBlock Text="CÓ HẠN"
                                                               FontSize="8" FontWeight="SemiBold"
                                                               Foreground="#FFFFFF"
                                                               FontFamily="Montserrat, Segoe UI"/>
                                                </Border>
                                            </Canvas>

                                            <!-- Body card -->
                                            <StackPanel Grid.Row="1">
                                                <!-- Đường kẻ vàng separator -->
                                                <Rectangle Height="1" Margin="14,0">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="Transparent" Offset="0"/>
                                                            <GradientStop Color="#E8D9B5" Offset="0.5"/>
                                                            <GradientStop Color="Transparent" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <TextBlock Text="{Binding TenKhuyenMai}"
                                                           FontFamily="Playfair Display, Georgia, serif"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="#2A1F0A"
                                                           Margin="14,12,14,5"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Text="{Binding MoTa}"
                                                           FontSize="10" Foreground="#A08050"
                                                           FontFamily="Montserrat, Segoe UI"
                                                           FontWeight="Light"
                                                           Margin="14,0,14,8"
                                                           TextWrapping="Wrap" LineHeight="16"/>

                                                <!-- Ngày -->
                                                <StackPanel Orientation="Horizontal" Margin="14,0,14,2">
                                                    <TextBlock Text="📅 " FontSize="10" Foreground="#A08050"/>
                                                    <TextBlock Text="{Binding NgayBatDau, StringFormat='dd/MM/yyyy'}"
                                                               FontSize="9" Foreground="#A08050"
                                                               FontFamily="Montserrat, Segoe UI"/>
                                                    <TextBlock Text=" – " FontSize="9" Foreground="#A08050"/>
                                                    <TextBlock Text="{Binding NgayKetThuc, StringFormat='dd/MM/yyyy'}"
                                                               FontSize="9" Foreground="#A08050"
                                                               FontFamily="Montserrat, Segoe UI"/>
                                                </StackPanel>

                                                <!-- Trạng thái + ngày còn lại -->
                                                <StackPanel Orientation="Horizontal" Margin="14,0,14,0">
                                                    <TextBlock Text="✅ " FontSize="9" Foreground="#C9A84C"/>
                                                    <TextBlock Text="{Binding TrangThai}"
                                                               FontSize="9" Foreground="#C9A84C"
                                                               FontFamily="Montserrat, Segoe UI"/>
                                                    <TextBlock Text="  |  Còn " FontSize="9" Foreground="#A08050"/>
                                                    <TextBlock Text="{Binding SoNgayConLai}"
                                                               FontSize="9" Foreground="#C9A84C"
                                                               FontFamily="Montserrat, Segoe UI" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" ngày" FontSize="9" Foreground="#A08050"/>
                                                </StackPanel>

                                                <Button Content="ÁP DỤNG NGAY"
                                                        Style="{StaticResource CardCtaButtonStyle}"
                                                        Tag="{Binding MaKhuyenMai}"
                                                        Click="ApplyPromotion_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- UserControl khi navigate -->
                <ContentControl x:Name="MainContent" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
